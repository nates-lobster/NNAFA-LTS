<Window x:Class="Frontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="NNAFA V0.2 LTS" Height="800" Width="1200"
        Background="#1E1E2E" Foreground="#CDD6F4"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Persistent Top Bar -->
        <Border Grid.Row="0" Background="#313244" Padding="15" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Integrity -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Signal Status: " FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
                    <TextBlock x:Name="TxtStatus" Text="WAITING" FontSize="18" FontWeight="Bold" Foreground="Gray" Margin="5,0"/>
                    <Ellipse x:Name="IntegrityLight" Width="20" Height="20" Fill="Gray" Margin="10,0"/>
                </StackPanel>
                
                <!-- Power Levels -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="δ (1-4Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDelta" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="θ (4-8Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTheta" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="α (8-12Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtAlpha" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="β (12-30Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtBeta" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="γ (30-40Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtGamma" Text="0.0" Width="40" Foreground="#A6ADC8" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="#1E1E2E" BorderThickness="0" Margin="10">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        ContentSource="Header"
                                        Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#89B4FA"/>
                                        <Setter Property="Foreground" Value="#89B4FA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="Padding" Value="10,5"/>
                </Style>
            </TabControl.Resources>

            <!-- Monitoring Tab -->
            <TabItem Header="Monitoring">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    
                    <UniformGrid Rows="2" Columns="2" Grid.Row="0" Margin="10">
                        <ScottPlot:WpfPlot x:Name="WpfPlotAF7" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotAF8" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotTP9" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotTP10" Margin="5"/>
                    </UniformGrid>
                    
                    <Grid Grid.Row="1" Margin="15,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" Panel.ZIndex="1">
                            <TextBlock Text="PSD View: " Foreground="#A6ADC8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton x:Name="RbStandard" Content="Standard" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbScale_Checked"/>
                            <RadioButton x:Name="RbCompensated" Content="Compensated (1/f)" Foreground="#CDD6F4" VerticalAlignment="Center" Checked="RbScale_Checked"/>
                        </StackPanel>
                        <ScottPlot:WpfPlot x:Name="WpfPlotPSD_Monitor" Grid.Row="1" PreviewMouseDown="WpfPlotPSD_PreviewMouseDown"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Neurofeedback Tab -->
            <TabItem Header="Neurofeedback">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel HorizontalAlignment="Center" Margin="0,20,0,0" Grid.Row="0">
                        <TextBlock Text="Smoothed Alpha/Beta Ratio" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="AlphaRatioText" Text="0.00" FontSize="72" FontWeight="Black" Foreground="#A6E3A1" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TargetRatioText" Text="Target: 1.00" FontSize="18" Foreground="#89B4FA" HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="AlphaRatioBar" Width="400" Height="20" Minimum="0" Maximum="3" Value="0" Margin="0,10" Foreground="#A6E3A1" Background="#313244"/>
                    </StackPanel>

                    <!-- Calibration & Audio Tools -->
                    <Border Grid.Row="1" Background="#313244" Padding="20" Margin="40,10" CornerRadius="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Session Calibration" FontWeight="Bold" Margin="0,0,0,5"/>
                                <Button x:Name="BtnCalibrate" Content="Start 30s Baseline" Click="BtnCalibrate_Click" Padding="10" Background="#89B4FA" Foreground="#11111B" FontWeight="Bold"/>
                                <ProgressBar x:Name="PbCalibration" Height="10" Margin="0,10,0,0" Background="#1E1E2E"/>
                                
                                <TextBlock Text="Manual Tuning (Difficulty)" Margin="0,15,0,5" FontSize="12" Foreground="#A6ADC8"/>
                                <Slider x:Name="SliderDifficulty" Minimum="-0.5" Maximum="0.5" Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,0,0,5"/>
                                <TextBlock x:Name="TxtDifficulty" Text="Offset: +0.00" HorizontalAlignment="Center" FontSize="10"/>

                                <TextBlock Text="Smoothing Window (sec)" Margin="0,15,0,5" FontSize="12" Foreground="#A6ADC8"/>
                                <Slider x:Name="SliderSmoothing" Minimum="0.5" Maximum="10.0" Value="1.0" TickFrequency="0.5" IsSnapToTickEnabled="True" Margin="0,0,0,5" ValueChanged="SliderSmoothing_ValueChanged"/>
                                <TextBlock x:Name="TxtSmoothing" Text="Window: 1.0s" HorizontalAlignment="Center" FontSize="10"/>

                                <Button x:Name="BtnRefresh" Content="Reset Session Buffers" Click="BtnRefresh_Click" Margin="0,15,0,0" Padding="5" Background="#45475A" Foreground="#CDD6F4"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Audio Feedback" FontWeight="Bold" Margin="0,0,0,5"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="BtnSelectAudio" Content="Select File" Click="BtnSelectAudio_Click" Padding="5" Margin="0,0,5,0"/>
                                    <TextBlock x:Name="TxtAudioFile" Text="No file selected" VerticalAlignment="Center" FontSize="12" Foreground="#A6ADC8"/>
                                </StackPanel>
                                <TextBlock x:Name="TxtVolume" Text="Volume: 0%" Margin="0,10,0,0" Foreground="#F9E2AF"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <ScottPlot:WpfPlot x:Name="WpfPlotPSD_NFB" Grid.Row="2" Margin="20" PreviewMouseDown="WpfPlotPSD_PreviewMouseDown"/>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="History">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Brainwave Trends (Last 30s)" FontSize="20" FontWeight="Bold" Margin="20,10" HorizontalAlignment="Center"/>
                    <ScottPlot:WpfPlot x:Name="WpfPlotHistory" Grid.Row="1" Margin="10"/>
                </Grid>
            </TabItem>

            <!-- Debug Pipeline Tab -->
            <TabItem Header="Debug Pipeline">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <TextBlock Text="Visualize Sensor: " VerticalAlignment="Center" FontSize="16" Margin="0,0,10,0" Foreground="#A6ADC8"/>
                        <RadioButton x:Name="RbDebugTP9" Content="TP9" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbDebug_Checked"/>
                        <RadioButton x:Name="RbDebugAF7" Content="AF7" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbDebug_Checked"/>
                        <RadioButton x:Name="RbDebugAF8" Content="AF8" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbDebug_Checked"/>
                        <RadioButton x:Name="RbDebugTP10" Content="TP10" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbDebug_Checked"/>
                        <RadioButton x:Name="RbDebugAvg" Content="Average" Foreground="#CDD6F4" VerticalAlignment="Center" Checked="RbDebug_Checked"/>
                    </StackPanel>

                    <UniformGrid Grid.Row="1" Rows="3" Columns="2" Margin="10">
                        <ScottPlot:WpfPlot x:Name="WpfPlotDebugRaw" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotDebugNotched" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotDebugFir" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotDebugFiltered" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotDebugPSD" Margin="5"/>
                    </UniformGrid>
                </Grid>
            </TabItem>

            <!-- Debug Overlay Tab -->
            <TabItem Header="Debug Overlay">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Layer Toggles -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                        <TextBlock Text="Layers: " VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#A6ADC8"/>
                        <CheckBox x:Name="CbShowRaw" Content="1. Raw" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="CbLayer_Changed" Unchecked="CbLayer_Changed"/>
                        <CheckBox x:Name="CbShowNotched" Content="2. Notch" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="CbLayer_Changed" Unchecked="CbLayer_Changed"/>
                        <CheckBox x:Name="CbShowFir" Content="3. FIR" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="CbLayer_Changed" Unchecked="CbLayer_Changed"/>
                        <CheckBox x:Name="CbShowIir" Content="4. IIR" IsChecked="True" Foreground="#CDD6F4" VerticalAlignment="Center" Checked="CbLayer_Changed" Unchecked="CbLayer_Changed"/>
                    </StackPanel>

                    <ScottPlot:WpfPlot x:Name="WpfPlotOverlay" Grid.Row="1" Margin="10"/>

                    <!-- Filter Mode Selection -->
                    <Border Grid.Row="2" Background="#313244" Padding="10" CornerRadius="5" Margin="20,0,20,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Filter Mode: " VerticalAlignment="Center" Margin="0,0,20,0" FontWeight="Bold" Foreground="#89B4FA"/>
                            <RadioButton x:Name="RbModeBoth" Content="Combined (FIR+IIR)" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,20,0" VerticalAlignment="Center" Checked="RbFilterMode_Checked"/>
                            <RadioButton x:Name="RbModeIirOnly" Content="Only IIR (Standard)" Foreground="#CDD6F4" Margin="0,0,20,0" VerticalAlignment="Center" Checked="RbFilterMode_Checked"/>
                            <RadioButton x:Name="RbModeFirOnly" Content="Only FIR (Linear Phase)" Foreground="#CDD6F4" VerticalAlignment="Center" Checked="RbFilterMode_Checked"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Research Tab -->
            <TabItem Header="Research &amp; Tools">
                <Grid>
                    <StackPanel Margin="20" Width="400" HorizontalAlignment="Left">
                        <TextBlock Text="Participant Metadata" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="ParticipantIdInput" Margin="0,5" Padding="5" FontSize="16" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>
                        <Button Content="Set Participant ID" Margin="0,10" Padding="10" Background="#89B4FA" Foreground="#11111B" FontWeight="Bold" BorderThickness="0"/>
                        
                        <TextBlock Text="LabRecorder Stream" FontSize="20" FontWeight="Bold" Margin="0,30,0,10"/>
                        <TextBlock Text="Port: 22345" FontSize="16" Foreground="#A6ADC8" Margin="0,0,0,10"/>
                        <Button Content="Connect LabRecorder" Margin="0,10" Padding="10" Background="#F9E2AF" Foreground="#11111B" FontWeight="Bold" BorderThickness="0"/>
                        
                        <TextBlock Text="Emergency Controls" FontSize="20" FontWeight="Bold" Margin="0,50,0,10" Foreground="#F38BA8"/>
                        <Button Content="Kill All Python" Click="KillPython_Click" Margin="0,10" Padding="10" Background="#F38BA8" Foreground="#11111B" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
