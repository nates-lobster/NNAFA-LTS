<Window x:Class="Frontend.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="NNAFA V0.2 LTS" Height="800" Width="1200"
        Background="#1E1E2E" Foreground="#CDD6F4"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Grid Background="#1E1E2E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Persistent Top Bar -->
        <Border Grid.Row="0" Background="#313244" Padding="15" Margin="0,0,0,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Integrity -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Signal Status: " FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"/>
                    <TextBlock x:Name="TxtStatus" Text="WAITING" FontSize="18" FontWeight="Bold" Foreground="Gray" Margin="5,0"/>
                    <Ellipse x:Name="IntegrityLight" Width="20" Height="20" Fill="Gray" Margin="10,0"/>
                </StackPanel>
                
                <!-- Power Levels -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="δ (1-4Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtDelta" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="θ (4-8Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTheta" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="α (8-12Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtAlpha" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="β (12-30Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtBeta" Text="0.0" Width="40" Foreground="#A6ADC8" Margin="0,0,10,0" FontWeight="Bold"/>
                    <TextBlock Text="γ (30-40Hz): " Foreground="#CDD6F4" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtGamma" Text="0.0" Width="40" Foreground="#A6ADC8" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Background="#1E1E2E" BorderThickness="0" Margin="10">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" BorderThickness="0,0,0,2" BorderBrush="Transparent" Margin="2,0">
                                    <ContentPresenter x:Name="ContentSite"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center"
                                        ContentSource="Header"
                                        Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#89B4FA"/>
                                        <Setter Property="Foreground" Value="#89B4FA"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Foreground" Value="#CDD6F4"/>
                    <Setter Property="FontSize" Value="16"/>
                    <Setter Property="Padding" Value="10,5"/>
                </Style>
            </TabControl.Resources>

            <!-- Monitoring Tab -->
            <TabItem Header="Monitoring">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    
                    <UniformGrid Rows="2" Columns="2" Grid.Row="0" Margin="10">
                        <ScottPlot:WpfPlot x:Name="WpfPlotAF7" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotAF8" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotTP9" Margin="5"/>
                        <ScottPlot:WpfPlot x:Name="WpfPlotTP10" Margin="5"/>
                    </UniformGrid>
                    
                    <Grid Grid.Row="1" Margin="15,5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0" Panel.ZIndex="1">
                            <TextBlock Text="PSD Scale: " Foreground="#A6ADC8" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton x:Name="RbMagnitude" Content="Magnitude" IsChecked="True" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbScale_Checked"/>
                            <RadioButton x:Name="RbLogarithmic" Content="Logarithmic" Foreground="#CDD6F4" Margin="0,0,10,0" VerticalAlignment="Center" Checked="RbScale_Checked"/>
                            <RadioButton x:Name="RbStandard" Content="Standard" Foreground="#CDD6F4" VerticalAlignment="Center" Checked="RbScale_Checked"/>
                        </StackPanel>
                        <ScottPlot:WpfPlot x:Name="WpfPlotPSD_Monitor" Grid.Row="1" PreviewMouseDown="WpfPlotPSD_PreviewMouseDown"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Neurofeedback Tab -->
            <TabItem Header="Neurofeedback">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20,0,0" Grid.Row="0">
                        <TextBlock Text="Live Alpha/Beta Ratio" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock x:Name="AlphaRatioText" Text="0.00" FontSize="72" FontWeight="Black" Foreground="#A6E3A1" HorizontalAlignment="Center"/>
                        <ProgressBar x:Name="AlphaRatioBar" Width="400" Height="30" Minimum="0" Maximum="3" Value="0" Margin="0,20" Foreground="#A6E3A1" Background="#313244"/>
                    </StackPanel>
                    
                    <ScottPlot:WpfPlot x:Name="WpfPlotPSD_NFB" Grid.Row="1" Margin="20" PreviewMouseDown="WpfPlotPSD_PreviewMouseDown"/>
                </Grid>
            </TabItem>

            <!-- Research Tab -->
            <TabItem Header="Research &amp; Tools">
                <Grid>
                    <StackPanel Margin="20" Width="400" HorizontalAlignment="Left">
                        <TextBlock Text="Participant Metadata" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBox x:Name="ParticipantIdInput" Margin="0,5" Padding="5" FontSize="16" Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>
                        <Button Content="Set Participant ID" Margin="0,10" Padding="10" Background="#89B4FA" Foreground="#11111B" FontWeight="Bold" BorderThickness="0"/>
                        
                        <TextBlock Text="LabRecorder Stream" FontSize="20" FontWeight="Bold" Margin="0,30,0,10"/>
                        <TextBlock Text="Port: 22345" FontSize="16" Foreground="#A6ADC8" Margin="0,0,0,10"/>
                        <Button Content="Connect LabRecorder" Margin="0,10" Padding="10" Background="#F9E2AF" Foreground="#11111B" FontWeight="Bold" BorderThickness="0"/>
                        
                        <TextBlock Text="Emergency Controls" FontSize="20" FontWeight="Bold" Margin="0,50,0,10" Foreground="#F38BA8"/>
                        <Button Content="Kill All Python" Click="KillPython_Click" Margin="0,10" Padding="10" Background="#F38BA8" Foreground="#11111B" FontWeight="Bold" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
